{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(node:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npm list:*)",
      "Bash(make:*)",
      "Bash(grep -v \"^d.*\\\\.$\")"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf --no-preserve-root:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(mkfs.*:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(shred:*)",
      "Bash(wipefs:*)",
      "Bash(sudo rm -rf:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opusplan",
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true
  }
}