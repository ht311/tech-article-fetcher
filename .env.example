# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LINE Developers コンソール > チャンネル > Messaging API > チャンネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# 送信先 LINE ユーザー ID（U で始まる文字列）
LINE_USER_ID=your_line_user_id_here

# LINE Channel Secret（Webhook 署名検証に使用）
# LINE Developers コンソール > チャンネル > チャンネル基本設定 > Channel secret
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Cloudflare（terraform apply 後に設定）
# Dashboard: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare アカウント ID（Dashboard の URL または右サイドバーに表示）
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# KV Namespace ID（terraform output kv_namespace_id で取得）
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id_here
